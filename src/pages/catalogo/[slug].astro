---
// Importar el archivo JSON directamente
import productosData from '../../data/productos.json';
import Layout from '../../layouts/Base.astro';

// Obtener el slug de la URL
const { slug } = Astro.params;

// Buscar el producto que coincida con el slug
const producto = productosData.productos.find(p => p.slug === slug);

// Si no existe el producto, mostrar 404
if (!producto) {
  return Astro.redirect("/404");
}
---

<Layout title={`${producto.nombre} - TiendaAstro`}>
  <main class="container mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row gap-8">
      
      {/* Imagen */}
      <img src={producto.imagen} alt={producto.nombre} class="w-full md:w-1/2 rounded-lg" />
      
      {/* Detalles */}
      <div class="flex-1">
        <h1 class="text-3xl font-bold mb-2">{producto.nombre}</h1>
        
        {/* Calificación */}
        <div class="flex items-center gap-2 mb-4">
          <div class="flex">
            {[...Array(5)].map((_, i) => (
              <span class={i < Math.floor(producto.promedioCalificacion) ? "text-yellow-500" : "text-gray-300"}>
                ★
              </span>
            ))}
          </div>
          <span>({producto.reviews.length} opiniones)</span>
        </div>

        <p class="text-gray-600 mb-4">{producto.descripcion}</p>
        <p class="text-2xl font-bold text-blue-600 mb-4">${producto.precio}</p>

        {/* Tallas */}
        <div class="mb-4">
          <span class="font-bold">Tallas:</span>
          <div class="flex gap-2 mt-1">
            {producto.tallas.map(talla => (
              <span class="px-2 py-1 border rounded">{talla}</span>
            ))}
          </div>
        </div>

        {/* Colores */}
        <div class="mb-4">
          <span class="font-bold">Colores:</span>
          <div class="flex gap-2 mt-1">
            {producto.colores.map(color => (
              <span class="px-2 py-1 border rounded">{color}</span>
            ))}
          </div>
        </div>
        
        {/* Marca y categoría */}
        <p class="mb-2"><span class="font-bold">Marca:</span> {producto.marca}</p>
        <p class="mb-4"><span class="font-bold">Categoría:</span> {producto.categoria}</p>
        
        {/* Stock */}
        <p class={`mb-4 ${producto.stock > 0 ? 'text-green-600' : 'text-red-600'}`}>
          {producto.stock > 0 ? `✅ Stock disponible: ${producto.stock} unidades` : '❌ Sin stock'}
        </p>
        
        <button class="bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700">
          Agregar al carrito
        </button>
      </div>
    </div>
    
    {/* Sección de opiniones */}
    <div class="mt-8">
      <h3 class="text-xl font-bold mb-4">Opiniones de clientes</h3>
      {producto.reviews.length === 0 ? (
        <p class="text-gray-500">Aún no hay opiniones para este producto.</p>
      ) : (
        producto.reviews.map(review => (
          <div class="border-b pb-4 mb-4">
            <div class="flex justify-between items-center">
              <p class="font-semibold">{review.autor}</p>
              <div class="flex">
                {[...Array(5)].map((_, i) => (
                  <span class={i < review.calificacion ? "text-yellow-500" : "text-gray-300"}>★</span>
                ))}
              </div>
            </div>
            {review.comentario && <p class="text-gray-700 mt-2">{review.comentario}</p>}
            {review.fecha && <p class="text-xs text-gray-400 mt-1">{new Date(review.fecha).toLocaleDateString()}</p>}
          </div>
        ))
      )}
    </div>
  </main>
</Layout>