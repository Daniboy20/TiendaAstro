---
import Layout from '../../layouts/Base.astro';
import productosData from '../../data/productos.json';
import ValoracionEstrellas from '../../components/catalogo/ValoracionEstrellas.astro';
import ListaReviews from '../../components/catalogo/Reviews.astro';

const { id } = Astro.params;
const producto = productosData.productos.find(p => p.slug === id);

if (!producto) {
  return Astro.redirect("/404");
}

const colorMap: Record<string, string> = {
  'Azul': '#2563EB',
  'Negro': '#1F2937',
  'Gris': '#9CA3AF',
  'Blanco': '#F3F4F6',
  'Rojo': '#DC2626',
  'Verde': '#10B981',
  'Amarillo': '#EAB308',
  'Rosa': '#EC4899',
  'Morado': '#8B5CF6',
  'Naranja': '#F97316',
  'Café': '#92400E',
  'Beige': '#D4B896',
};

// Fix error ts(2352): extraer imagenes como unknown primero
const imagenesObj = (producto.imagenes as unknown as Record<string, string[]>) ?? {};

const coloresConHex = (producto.colores ?? []).map(color => ({
  nombre: color,
  hex: colorMap[color] ?? '#CBD5E1',
  esClaro: color === 'Blanco' || color === 'Beige',
  imagenes: imagenesObj[color] ?? [],
}));

const imagenesIniciales: string[] = (() => {
  for (const c of coloresConHex) {
    if (c.imagenes.length > 0) return c.imagenes;
  }
  return [];
})();

const piezas = (producto.piezas ?? []).map(
  (slug: string) => productosData.productos.find(p => p.slug === slug)
).filter(Boolean);

const coloresJSON = JSON.stringify(
  coloresConHex.map(c => ({ nombre: c.nombre, imagenes: c.imagenes }))
);
---

<Layout title={`${producto.nombre} - TiendaAstro`}>
  <main class="container mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row gap-8">

      {/* Galería */}
      <div class="w-full md:w-1/2 flex flex-col gap-3">
        <img
          src={imagenesIniciales[0]}
          alt={producto.nombre}
          id="imagen-principal"
          class="w-full rounded-lg object-cover aspect-square"
        />
        <div id="miniaturas" class="flex gap-2 flex-wrap">
          {imagenesIniciales.map((img, i) => (
            <img
              src={img}
              alt={`${producto.nombre} vista ${i + 1}`}
              class={`miniatura w-20 h-20 object-cover rounded-md cursor-pointer border-2 transition-all ${i === 0 ? 'border-blue-500' : 'border-gray-200 opacity-60'}`}
              data-src={img}
            />
          ))}
        </div>
      </div>

      {/* Detalles */}
      <div class="flex-1">
        <h1 class="text-3xl font-bold mb-2">{producto.nombre}</h1>

        <div class="flex items-center gap-2 mb-4">
          <ValoracionEstrellas calificacion={producto.promedioCalificacion || 0} />
          <span class="text-gray-500">({producto.reviews.length} opiniones)</span>
        </div>

        <p class="mb-4 whitespace-pre-line">{producto.descripcion}</p>
        <p class="text-2xl font-bold text-blue-600 mb-6">L. {producto.precio.toFixed(2)}</p>

        {producto.tallas && producto.tallas.length > 0 && (
          <div class="mb-6">
            <span class="font-bold block mb-2">
              Talla: <span id="talla-seleccionada" class="font-normal text-gray-500">—</span>
            </span>
            <div class="flex flex-wrap gap-2">
              {producto.tallas.map((talla) => (
                <button class="talla-btn px-4 py-2 border border-gray-300 rounded-md transition-colors hover:border-blue-500" data-talla={talla}>
                  {talla}
                </button>
              ))}
            </div>
          </div>
        )}

        {coloresConHex.length > 0 && (
          <div class="mb-6">
            <span class="font-bold block mb-2">
              Color: <span id="color-seleccionado-label" class="font-normal text-gray-500">—</span>
            </span>
            <div class="flex flex-wrap gap-3">
              {coloresConHex.map(({ nombre, hex, esClaro }) => (
                <div class="flex flex-col items-center gap-1">
                  <button
                    class="color-btn w-10 h-10 rounded-full border-2 border-gray-300 hover:scale-110 transition-transform focus:outline-none"
                    style={`background-color: ${hex}${esClaro ? '; box-shadow: inset 0 0 0 1px #ccc' : ''}`}
                    title={nombre}
                    data-color={nombre}
                  />
                  <span class="text-xs">{nombre}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <p class="mb-2"><span class="font-bold">Marca:</span> {producto.marca}</p>
        <p class="mb-4"><span class="font-bold">Categoría:</span> {producto.categoria}</p>

        <p class={`mb-4 ${producto.stock > 0 ? 'text-green-600' : 'text-red-600'}`}>
          {producto.stock > 0 ? `✅ Stock disponible: ${producto.stock} unidades` : '❌ Sin stock'}
        </p>

        <button id="btn-carrito" class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors w-full md:w-auto">
          Agregar al carrito
        </button>

        {piezas.length > 0 && (
          <div class="mt-6 p-4 bg-gray-50 rounded-lg border">
            <p class="font-bold mb-2">¿Solo quieres una pieza?</p>
            <div class="flex flex-col gap-2">
              {piezas.map((pieza) => pieza && (
                <a href={`/productos/${pieza.slug}`} class="text-blue-600 hover:underline">
                  → {pieza.nombre} — L. {pieza.precio.toFixed(2)}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <ListaReviews reviews={producto.reviews} />
  </main>
</Layout>

<script define:vars={{ coloresJSON }}>
  const colores = JSON.parse(coloresJSON);
  const imagenPrincipal = document.getElementById('imagen-principal');
  const contenedorMiniaturas = document.getElementById('miniaturas');
  const tallaLabel = document.getElementById('talla-seleccionada');
  const colorLabel = document.getElementById('color-seleccionado-label');
  const tallaBtns = document.querySelectorAll('.talla-btn');
  const colorBtns = document.querySelectorAll('.color-btn');

  function seleccionarMiniatura(miniatura) {
    if (!imagenPrincipal) return;
    imagenPrincipal.src = miniatura.dataset.src;
    document.querySelectorAll('.miniatura').forEach(m => {
      m.classList.remove('border-blue-500');
      m.classList.add('border-gray-200', 'opacity-60');
    });
    miniatura.classList.add('border-blue-500');
    miniatura.classList.remove('border-gray-200', 'opacity-60');
  }

  function actualizarGaleria(imagenes) {
    if (!contenedorMiniaturas || !imagenPrincipal || !imagenes?.length) return;
    imagenPrincipal.src = imagenes[0];
    contenedorMiniaturas.innerHTML = '';
    imagenes.forEach((src, i) => {
      const img = document.createElement('img');
      img.src = src;
      img.alt = `Vista ${i + 1}`;
      img.dataset.src = src;
      img.className = `miniatura w-20 h-20 object-cover rounded-md cursor-pointer border-2 transition-all ${i === 0 ? 'border-blue-500' : 'border-gray-200 opacity-60'}`;
      img.addEventListener('click', () => seleccionarMiniatura(img));
      contenedorMiniaturas.appendChild(img);
    });
  }

  document.querySelectorAll('.miniatura').forEach(m => {
    m.addEventListener('click', () => seleccionarMiniatura(m));
  });

  tallaBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tallaBtns.forEach(b => {
        b.classList.remove('bg-blue-500', 'text-white', 'border-blue-500');
        b.classList.add('border-gray-300');
      });
      btn.classList.add('bg-blue-500', 'text-white', 'border-blue-500');
      btn.classList.remove('border-gray-300');
      if (tallaLabel) tallaLabel.textContent = btn.dataset.talla ?? '—';
    });
  });

  colorBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      colorBtns.forEach(b => b.classList.remove('ring-2', 'ring-blue-500', 'ring-offset-2'));
      btn.classList.add('ring-2', 'ring-blue-500', 'ring-offset-2');
      if (colorLabel) colorLabel.textContent = btn.dataset.color ?? '—';
      const colorData = colores.find(c => c.nombre === btn.dataset.color);
      if (colorData?.imagenes?.length) actualizarGaleria(colorData.imagenes);
    });
  });

  // Auto-seleccionar primer color al cargar
  const primerColorBtn = document.querySelector('.color-btn');
  if (primerColorBtn) primerColorBtn.click();
</script>
