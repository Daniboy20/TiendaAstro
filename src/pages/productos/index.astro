---
import Layout from '../../layouts/Base.astro';
import productosData from '../../data/productos.json';
import ProductCard from '../../components/catalogo/ProductCard.astro';

const todos = productosData.productos as any[];

const generos = [...new Set(todos.map(p => p.genero).filter(Boolean))].sort();
const tipos = [...new Set(todos.map(p => p.tipo).filter(Boolean))].sort();
const todasCategorias = [...new Set(todos.map(p => p.categoria).filter(Boolean))].sort();
const marcas = [...new Set(todos.map(p => p.marca).filter(Boolean))].sort();
const coloresUnicos = [...new Set(todos.flatMap(p => p.colores ?? []))].sort();

const precios = todos.map(p => p.precio);
const precioMin = precios.length > 0 ? Math.floor(Math.min(...precios)) : 0;
const precioMax = precios.length > 0 ? Math.ceil(Math.max(...precios)) : 9999;

const colorMap: Record<string, string> = {
  'Azul': '#2563EB',
  'Negro': '#1F2937',
  'Gris': '#9CA3AF',
  'Blanco': '#F3F4F6',
  'Rojo': '#DC2626',
  'Verde': '#10B981',
  'Amarillo': '#EAB308',
  'Rosa': '#EC4899',
  'Morado': '#8B5CF6',
  'Naranja': '#F97316',
  'Café': '#92400E',
  'Beige': '#D4B896',
};
---

<Layout title="Todos los Productos - TiendaAstro">
  <main class="container mx-auto px-4 py-8">

    <nav class="text-sm text-gray-500 mb-6 flex items-center gap-2 flex-wrap">
      <a href="/" class="hover:text-blue-600">Inicio</a>
      <span>›</span>
      <a href="/productos" class="hover:text-blue-600 text-gray-900 font-semibold">Productos</a>
      <span id="breadcrumb-filtros"></span>
    </nav>

    <h1 id="titulo-productos" class="text-3xl font-bold mb-8">
      Todos los Productos
    </h1>

    <div class="flex flex-col md:flex-row gap-8">

      <aside class="w-full md:w-52 shrink-0">

        <div class="mb-6">
          <h2 class="font-bold text-xs uppercase tracking-widest text-gray-400 mb-2">Género</h2>
          <ul class="flex flex-col gap-1">
            <li>
              <a href="/productos" class="filtro-link text-sm py-1 block hover:text-blue-600" data-clear-key="genero">
                Todos
              </a>
            </li>
            {generos.map(genero => (
              <li>
                <a
                  href={`/productos?genero=${encodeURIComponent(genero)}`}
                  class="filtro-link text-sm py-1 block hover:text-blue-600"
                  data-filter-key="genero"
                  data-filter-value={genero}
                >
                  {genero}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="mb-6">
          <h2 class="font-bold text-xs uppercase tracking-widest text-gray-400 mb-2">Tipo</h2>
          <ul class="flex flex-col gap-1">
            <li>
              <a href="/productos" class="filtro-link text-sm py-1 block hover:text-blue-600" data-clear-key="tipo">
                Todos
              </a>
            </li>
            {tipos.map(tipo => (
              <li>
                <a
                  href={`/productos?tipo=${encodeURIComponent(tipo)}`}
                  class="filtro-link text-sm py-1 block hover:text-blue-600"
                  data-filter-key="tipo"
                  data-filter-value={tipo}
                >
                  {tipo}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="mb-6">
          <h2 class="font-bold text-xs uppercase tracking-widest text-gray-400 mb-2">Categoría</h2>
          <ul class="flex flex-col gap-1">
            <li>
              <a href="/productos" class="filtro-link text-sm py-1 block hover:text-blue-600" data-clear-key="categoria">
                Todas
              </a>
            </li>
            {todasCategorias.map(categoria => (
              <li>
                <a
                  href={`/productos?categoria=${encodeURIComponent(categoria)}`}
                  class="filtro-link text-sm py-1 block hover:text-blue-600"
                  data-filter-key="categoria"
                  data-filter-value={categoria}
                >
                  {categoria}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="mb-6">
          <h2 class="font-bold text-xs uppercase tracking-widest text-gray-400 mb-2">Marca</h2>
          <ul class="flex flex-col gap-1">
            <li>
              <a href="/productos" class="filtro-link text-sm py-1 block hover:text-blue-600" data-clear-key="marca">
                Todas
              </a>
            </li>
            {marcas.map(marca => (
              <li>
                <a
                  href={`/productos?marca=${encodeURIComponent(marca)}`}
                  class="filtro-link text-sm py-1 block hover:text-blue-600"
                  data-filter-key="marca"
                  data-filter-value={marca}
                >
                  {marca}
                </a>
              </li>
            ))}
          </ul>
        </div>

        {coloresUnicos.length > 0 && (
          <div class="mb-6">
            <h2 class="font-bold text-xs uppercase tracking-widest text-gray-400 mb-2">Color</h2>
            <div class="flex flex-wrap gap-2">
              {coloresUnicos.map(color => {
                const hex = colorMap[color] ?? '#CBD5E1';
                const esClaro = color === 'Blanco' || color === 'Beige';

                return (
                  <button
                    type="button"
                    class="filtro-color flex flex-col items-center gap-1 group"
                    data-color={color}
                    title={color}
                  >
                    <span
                      class="circulo-color w-7 h-7 rounded-full border-2 border-gray-300 group-hover:scale-110 transition-transform"
                      style={`background-color: ${hex}${esClaro ? '; box-shadow: inset 0 0 0 1px #ccc' : ''}`}
                    />
                    <span class="text-xs text-gray-600">{color}</span>
                  </button>
                );
              })}
            </div>

            <button id="limpiar-color" type="button" class="text-xs text-red-400 hover:underline mt-2 hidden">
              ✕ Quitar color
            </button>
          </div>
        )}

        <div class="mb-6">
          <h2 class="font-bold text-xs uppercase tracking-widest text-gray-400 mb-2">Precio (L.)</h2>

          <div class="flex gap-2 items-center">
            <input
              id="precio-min"
              type="number"
              placeholder={String(precioMin)}
              class="w-full border rounded px-2 py-1 text-sm"
            />
            <span class="text-gray-400 text-sm">—</span>
            <input
              id="precio-max"
              type="number"
              placeholder={String(precioMax)}
              class="w-full border rounded px-2 py-1 text-sm"
            />
          </div>

          <button id="aplicar-precio" type="button" class="mt-2 text-xs bg-gray-900 text-white px-3 py-1 rounded hover:bg-gray-700 transition-colors">
            Aplicar
          </button>

          <button id="limpiar-precio" type="button" class="text-xs text-red-400 hover:underline mt-1 ml-2 hidden">
            ✕ Quitar
          </button>
        </div>

        <a href="/productos" id="limpiar-todos" class="text-sm text-red-500 hover:underline block mt-2 hidden">
          ✕ Limpiar todos los filtros
        </a>

      </aside>

      <div class="flex-1">
        <p class="text-sm text-gray-500 mb-4">
          <span id="contador">{todos.length}</span> producto<span id="plural-productos">s</span>
        </p>

        <div id="grid-productos" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {todos.map(producto => (
            <div
              class="producto-card"
              data-slug={producto.slug}
              data-nombre={producto.nombre}
              data-marca={producto.marca}
              data-categoria={producto.categoria}
              data-genero={producto.genero}
              data-tipo={producto.tipo}
              data-descripcion={producto.descripcion}
              data-colores={JSON.stringify(producto.colores ?? [])}
              data-precio={producto.precio}
            >
              <ProductCard producto={producto} slug={producto.slug} />
            </div>
          ))}
        </div>

        <p id="sin-resultados" class="text-gray-500 hidden">
          No se encontraron productos con los filtros seleccionados.
        </p>
      </div>

    </div>
  </main>
</Layout>

<script is:inline>
  function getData(elemento, nombre) {
    return elemento.getAttribute(`data-${nombre}`) || "";
  }

  function normalizar(texto) {
    return String(texto || "")
      .toLowerCase()
      .trim()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");
  }

  var colorActivo = null;
  var precioMinActivo = null;
  var precioMaxActivo = null;

  var cards = document.querySelectorAll(".producto-card");
  var contador = document.getElementById("contador");
  var pluralProductos = document.getElementById("plural-productos");
  var sinResultados = document.getElementById("sin-resultados");
  var limpiarColor = document.getElementById("limpiar-color");
  var limpiarPrecio = document.getElementById("limpiar-precio");
  var limpiarTodos = document.getElementById("limpiar-todos");
  var tituloProductos = document.getElementById("titulo-productos");
  var breadcrumbFiltros = document.getElementById("breadcrumb-filtros");

  function getParams() {
    return new URLSearchParams(window.location.search);
  }

  function getFiltro(nombre) {
    var params = getParams();
    return normalizar(params.get(nombre) || "");
  }

  function actualizarURL(key, value) {
    var params = getParams();

    if (value && value !== "") {
      params.set(key, value);
    } else {
      params.delete(key);
    }

    var nuevaUrl = params.toString()
      ? "/productos?" + params.toString()
      : "/productos";

    window.history.pushState({}, "", nuevaUrl);
    aplicarFiltros();
  }

  function actualizarTitulo() {
    var params = getParams();
    var partes = [];

    var genero = params.get("genero");
    var tipo = params.get("tipo");
    var categoria = params.get("categoria");
    var marca = params.get("marca");
    var q = params.get("q");

    if (genero) partes.push(genero);
    if (tipo) partes.push(tipo);
    if (categoria) partes.push(categoria);
    if (marca) partes.push(marca);
    if (q) partes.push('"' + q + '"');

    var titulo = partes.length > 0 ? partes.join(" · ") : "Todos los Productos";

    if (tituloProductos) {
      tituloProductos.textContent = titulo;
    }

    if (breadcrumbFiltros) {
      breadcrumbFiltros.textContent = partes.length > 0 ? "› " + titulo : "";
    }

    if (limpiarTodos) {
      var mostrarLimpiar =
        partes.length > 0 ||
        colorActivo !== null ||
        precioMinActivo !== null ||
        precioMaxActivo !== null;

      limpiarTodos.classList.toggle("hidden", !mostrarLimpiar);
    }
  }

  function actualizarLinksActivos() {
    var params = getParams();
    var links = document.querySelectorAll(".filtro-link");

    links.forEach(function (link) {
      var filterKey = link.getAttribute("data-filter-key");
      var filterValue = link.getAttribute("data-filter-value");
      var clearKey = link.getAttribute("data-clear-key");

      link.classList.remove("text-blue-600", "font-semibold");

      if (filterKey && normalizar(params.get(filterKey) || "") === normalizar(filterValue || "")) {
        link.classList.add("text-blue-600", "font-semibold");
      }

      if (clearKey && !params.has(clearKey)) {
        link.classList.add("text-blue-600", "font-semibold");
      }
    });
  }

  function aplicarFiltros() {
    var genero = getFiltro("genero");
    var marca = getFiltro("marca");
    var categoria = getFiltro("categoria");
    var tipo = getFiltro("tipo");
    var q = getFiltro("q");

    var visibles = 0;

    cards.forEach(function (card) {
      var nombre = normalizar(getData(card, "nombre"));
      var marcaProducto = normalizar(getData(card, "marca"));
      var categoriaProducto = normalizar(getData(card, "categoria"));
      var generoProducto = normalizar(getData(card, "genero"));
      var tipoProducto = normalizar(getData(card, "tipo"));
      var descripcionProducto = normalizar(getData(card, "descripcion"));
      var slugProducto = normalizar(getData(card, "slug"));

      var colores = [];

      try {
        colores = JSON.parse(getData(card, "colores") || "[]");
      } catch (error) {
        colores = [];
      }

      var coloresNormalizados = colores.map(function (color) {
        return normalizar(color);
      });

      var precio = Number.parseFloat(getData(card, "precio") || "0");

      var coincideGenero = !genero || generoProducto === genero;
      var coincideMarca = !marca || marcaProducto === marca;
      var coincideCategoria = !categoria || categoriaProducto === categoria;
      var coincideTipo = !tipo || tipoProducto === tipo;

      var coincideBusqueda =
        !q ||
        nombre.includes(q) ||
        marcaProducto.includes(q) ||
        categoriaProducto.includes(q) ||
        generoProducto.includes(q) ||
        tipoProducto.includes(q) ||
        descripcionProducto.includes(q) ||
        slugProducto.includes(q);

      var pasaColor =
        !colorActivo || coloresNormalizados.includes(normalizar(colorActivo));

      var pasaPrecioMin =
        precioMinActivo === null || precio >= precioMinActivo;

      var pasaPrecioMax =
        precioMaxActivo === null || precio <= precioMaxActivo;

      var visible =
        coincideGenero &&
        coincideMarca &&
        coincideCategoria &&
        coincideTipo &&
        coincideBusqueda &&
        pasaColor &&
        pasaPrecioMin &&
        pasaPrecioMax;

      card.classList.toggle("hidden", !visible);

      if (visible) {
        visibles++;
      }
    });

    if (contador) {
      contador.textContent = String(visibles);
    }

    if (pluralProductos) {
      pluralProductos.textContent = visibles === 1 ? "" : "s";
    }

    if (sinResultados) {
      sinResultados.classList.toggle("hidden", visibles > 0);
    }

    actualizarTitulo();
    actualizarLinksActivos();
  }

  document.querySelectorAll(".filtro-link").forEach(function (link) {
    link.addEventListener("click", function (event) {
      event.preventDefault();

      var filterKey = link.getAttribute("data-filter-key");
      var filterValue = link.getAttribute("data-filter-value");
      var clearKey = link.getAttribute("data-clear-key");

      if (filterKey) {
        actualizarURL(filterKey, filterValue);
      }

      if (clearKey) {
        actualizarURL(clearKey, null);
      }
    });
  });

  document.querySelectorAll(".filtro-color").forEach(function (boton) {
    boton.addEventListener("click", function () {
      var color = boton.getAttribute("data-color");

      colorActivo = colorActivo === color ? null : color;

      document.querySelectorAll(".circulo-color").forEach(function (circulo) {
        circulo.classList.remove("ring-2", "ring-blue-500", "ring-offset-1");
      });

      if (colorActivo) {
        var circuloActivo = boton.querySelector(".circulo-color");

        if (circuloActivo) {
          circuloActivo.classList.add("ring-2", "ring-blue-500", "ring-offset-1");
        }
      }

      if (limpiarColor) {
        limpiarColor.classList.toggle("hidden", !colorActivo);
      }

      aplicarFiltros();
    });
  });

  if (limpiarColor) {
    limpiarColor.addEventListener("click", function () {
      colorActivo = null;

      document.querySelectorAll(".circulo-color").forEach(function (circulo) {
        circulo.classList.remove("ring-2", "ring-blue-500", "ring-offset-1");
      });

      limpiarColor.classList.add("hidden");
      aplicarFiltros();
    });
  }

  var botonAplicarPrecio = document.getElementById("aplicar-precio");

  if (botonAplicarPrecio) {
    botonAplicarPrecio.addEventListener("click", function () {
      var minInput = document.getElementById("precio-min");
      var maxInput = document.getElementById("precio-max");

      var minVal = minInput ? minInput.value : "";
      var maxVal = maxInput ? maxInput.value : "";

      precioMinActivo = minVal ? Number.parseFloat(minVal) : null;
      precioMaxActivo = maxVal ? Number.parseFloat(maxVal) : null;

      if (limpiarPrecio) {
        limpiarPrecio.classList.toggle("hidden", !minVal && !maxVal);
      }

      aplicarFiltros();
    });
  }

  if (limpiarPrecio) {
    limpiarPrecio.addEventListener("click", function () {
      precioMinActivo = null;
      precioMaxActivo = null;

      var minInput = document.getElementById("precio-min");
      var maxInput = document.getElementById("precio-max");

      if (minInput) minInput.value = "";
      if (maxInput) maxInput.value = "";

      limpiarPrecio.classList.add("hidden");
      aplicarFiltros();
    });
  }

  if (limpiarTodos) {
    limpiarTodos.addEventListener("click", function (event) {
      event.preventDefault();

      window.history.pushState({}, "", "/productos");

      colorActivo = null;
      precioMinActivo = null;
      precioMaxActivo = null;

      var minInput = document.getElementById("precio-min");
      var maxInput = document.getElementById("precio-max");

      if (minInput) minInput.value = "";
      if (maxInput) maxInput.value = "";

      if (limpiarColor) limpiarColor.classList.add("hidden");
      if (limpiarPrecio) limpiarPrecio.classList.add("hidden");

      document.querySelectorAll(".circulo-color").forEach(function (circulo) {
        circulo.classList.remove("ring-2", "ring-blue-500", "ring-offset-1");
      });

      aplicarFiltros();
    });
  }

  window.addEventListener("popstate", function () {
    aplicarFiltros();
  });

  aplicarFiltros();
</script>