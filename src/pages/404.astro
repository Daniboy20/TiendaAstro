---
import Base from "@/layouts/Base.astro";
---

<Base title="Page Not Found">
  <section class="section-sm text-center">
    <div class="container">
      <div class="row justify-center">
        <div class="sm:col-10 md:col-8 lg:col-6">
          <span
            class="text-[8rem] block font-bold text-text-dark dark:text-darkmode-text-dark"
          >
            404
          </span>
          <h1 class="h2 mb-4">Pagina no encontrada</h1>
          <div class="content">
            <p>
              Esta pagina se encuentra en mantenimiento o no existe, por favor regresa a la pagina de inicio para seguir navegando.
            </p>
          </div>
          <a href="/" class="btn btn-primary mt-8"> Regresar a la pagina de inicio </a>
        </div>
      </div>
    </div>
  </section>
</Base>
