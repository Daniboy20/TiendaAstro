---
import Layout from '../layouts/Base.astro';
import productosData from '../data/productos.json';
import ProductCard from '../components/catalogo/ProductCard.astro';

const destacados = (productosData.productos as any[]).filter(p => p.destacado);
---

<Layout title="TiendaAstro - Ropa Deportiva">

  {/* HERO */}
  <section class="relative bg-gray-900 text-white py-24 px-6 text-center">
    <h1 class="text-5xl font-bold mb-4 text-white">Entrena con estilo</h1>
    <p class="text-lg mb-8 text-white opacity-80">Ropa deportiva importada de las mejores marcas</p>
    <div class="flex justify-center gap-4 flex-wrap">
      <a href="/productos?genero=Mujer"
        class="bg-white text-gray-900 font-semibold px-8 py-3 rounded-full hover:bg-gray-100 transition-colors">
        Mujer
      </a>
      <a href="/productos?genero=Hombre"
        class="border border-white text-white font-semibold px-8 py-3 rounded-full hover:bg-white hover:text-gray-900 transition-colors">
        Hombre
      </a>
    </div>
  </section>

  {/* ACCESOS POR CATEGORÍA */}
  <section class="container mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold mb-8 text-center dark:text-white">Explora por categoría</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        { label: 'Mujer · Superiores', href: '/productos?genero=Mujer&tipo=Superior' },
        { label: 'Mujer · Inferiores', href: '/productos?genero=Mujer&tipo=Inferior' },
        { label: 'Hombre · Superiores', href: '/productos?genero=Hombre&tipo=Superior' },
        { label: 'Hombre · Inferiores', href: '/productos?genero=Hombre&tipo=Inferior' },
      ].map(({ label, href }) => (
        <a href={href}
          class="block bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-800 dark:text-white font-semibold text-center py-8 rounded-xl transition-colors">
          {label}
        </a>
      ))}
    </div>
  </section>

  {/* ACCESOS POR MARCA */}
  <section class="bg-gray-50 dark:bg-gray-900 py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold mb-8 text-center dark:text-white">Nuestras marcas</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {['GymShark', 'Old Navy', 'YoungLA', 'Oner Active'].map(marca => (
          <a href={`/productos?marca=${encodeURIComponent(marca)}`}
            class="block bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:border-blue-500 dark:hover:border-blue-400 hover:shadow-md text-gray-800 dark:text-white font-semibold text-center py-8 rounded-xl transition-all">
            {marca}
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* PRODUCTOS DESTACADOS */}
  {destacados.length > 0 && (
    <section class="container mx-auto px-4 py-16">
      <h2 class="text-2xl font-bold mb-8 text-center dark:text-white">Destacados</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {destacados.map(producto => (
          <ProductCard producto={producto} slug={producto.slug} />
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/productos" class="bg-slate-900 text-white px-8 py-3 rounded-full hover:bg-blue-700 transition-colors">
          Ver todos los productos
        </a>
      </div>
    </section>
  )}

</Layout>
