---
const { producto, slug } = Astro.props;
---

<a href={`/catalogo/${slug}`} class="block border rounded-lg p-4 hover:shadow-lg transition-shadow">
  <img src={producto.imagen} alt={producto.nombre} class="w-full h-48 object-cover rounded" />
  <h3 class="text-xl font-bold mt-2">{producto.nombre}</h3>
  <p class="text-gray-600">{producto.marca}</p>
  <p class="text-blue-600 font-bold mt-2">${producto.precio}</p>
  <div class="mt-2">
    <ValoracionEstrellas calificacion={producto.promedioCalificacion || 0} />
  </div>
</a>