---
import config from "@/config/config.json";

type Product = {
  title: string;
  handle: string;
  featuredImage?: {
    url?: string;
    altText?: string;
  };
  priceRange: {
    minVariantPrice: {
      amount: string | number;
    };
  };
  compareAtPriceRange?: {
    maxVariantPrice?: {
      amount?: string | number;
      currencyCode?: string;
    };
  };
};

interface Props {
  products: Product[];
}

const { products } = Astro.props;
const { currencySymbol } = config.shopify;
---

<div class="row">
  {
    products.map((product) => {
      const { title, handle, featuredImage, priceRange, compareAtPriceRange } =
        product;

      return (
        <div class="text-center col-6 md:col-4 lg:col-3 mb-8 md:mb-14 group relative">
          <div class="relative overflow-hidden">
            <img
              src={featuredImage?.url || "/images/product-placeholder.jpg"}
              width={312}
              height={269}
              alt={featuredImage?.altText || title}
              class="w-[312px] h-[150px] md:h-[269px] object-cover border border-border rounded-md"
            />

            <a
              href={`/products/${handle}`}
              class="btn btn-primary max-md:btn-sm z-10 absolute bottom-12 md:bottom-0 left-1/2 transform -translate-x-1/2 translate-y-full md:group-hover:-translate-y-6 duration-300 ease-in-out whitespace-nowrap drop-shadow-md"
            >
              Ver producto
            </a>
          </div>

          <div class="py-2 md:py-4 text-center z-20">
            <h2 class="font-medium text-base md:text-xl">
              <a class="after:absolute after:inset-0" href={`/products/${handle}`}>
                {title}
              </a>
            </h2>

            <div class="flex flex-wrap justify-center items-center gap-x-2 mt-2 md:mt-4">
              <span class="text-base md:text-xl font-bold text-text-dark dark:text-darkmode-text-dark">
                {currencySymbol}
                {priceRange.minVariantPrice.amount}
              </span>

              {Number(compareAtPriceRange?.maxVariantPrice?.amount || 0) > 0 && (
                <s class="text-text-light dark:text-darkmode-text-light text-xs md:text-base font-medium">
                  {currencySymbol}
                  {compareAtPriceRange?.maxVariantPrice?.amount}
                </s>
              )}
            </div>
          </div>
        </div>
      );
    })
  }
</div>

<div class="flex justify-center">
  <a class="btn btn-sm md:btn-lg btn-primary font-medium" href="/products">
    + Todos los Productos
  </a>
</div>